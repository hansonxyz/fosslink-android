    <!-- Samsung deep-sleep wizard step -->
    <string name="samsung_screen_title">Samsung Battery Settings</string>
    <string name="samsung_screen_intro">FossLink runs in the background to keep your phone connected to your desktop. Samsung phones aggressively put background apps to sleep, even ones running as foreground services, which will cause FossLink to silently disconnect when the screen is locked.</string>
    <string name="samsung_screen_what_to_do">To prevent this:</string>
    <string name="samsung_screen_step1">1. Tap "Open Device Care" below.</string>
    <string name="samsung_screen_step2">2. Open "Background usage limits" (or "Sleeping apps" depending on your Android version).</string>
    <string name="samsung_screen_step3">3. Add FossLink to the "Never sleeping apps" list (or remove it from "Sleeping apps" / "Deep sleeping apps" if it appears there).</string>
    <string name="samsung_screen_open_btn">Open Device Care</string>
    <string name="samsung_screen_continue_disabled_hint">Tap "Open Device Care" first to continue</string>
    <string name="samsung_screen_continue">Continue</string>
    <string name="samsung_screen_close">Close</string>

